
# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Replace with your MongoDB connection string
# Example: mongodb://localhost:27017/smartclinic
# Or use MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/smartclinic
MONGODB_URI=mongodb://localhost:27017/smartclinic

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=30d

# Frontend URL (optional)
# Use this for local development. On Render, the app can use RENDER_EXTERNAL_HOSTNAME automatically.
FRONTEND_URL=http://localhost:5173
